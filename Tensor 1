import numpy as np
import matplotlib.pyplot as plt

#Circulo de Mohr para un tensor de esfuerzos dado por el usuario

# 🔹 1. Ingresar tensor de esfuerzos
print("Introduce el tensor de esfuerzos 3x3 fila por fila:")

sigma = []
for i in range(3):
    fila = list(map(float, input(f"Fila {i+1}: ").split()))
    sigma.append(fila)

sigma = np.array(sigma)

# Validación
if sigma.shape != (3,3):
    raise ValueError("El tensor debe ser 3x3")

import numpy as np
import matplotlib.pyplot as plt


# Resolución
N = 120

sigma_n_vals = []
tau_vals = []

theta = np.linspace(0, np.pi, N)
phi = np.linspace(0, 2*np.pi, N)

for i in range(N):
    for j in range(N):
        
        nx = np.sin(theta[i]) * np.cos(phi[j])
        ny = np.sin(theta[i]) * np.sin(phi[j])
        nz = np.cos(theta[i])
        
        n = np.array([nx, ny, nz])

        #Vector de Tracción

        T = sigma @ n
        sigma_n = np.dot(T, n)
        
        tau = np.linalg.norm(T - sigma_n * n)
        
        sigma_n_vals.append(sigma_n)
        tau_vals.append(tau)

# Gráfica completa (IMPORTANTE)
plt.figure()
plt.scatter(sigma_n_vals, tau_vals, s=1)
plt.scatter(sigma_n_vals, -np.array(tau_vals), s=1)

plt.xlabel("σ_n")
plt.ylabel("τ")
plt.title("Región de estados de esfuerzo")
plt.grid()
plt.show()
